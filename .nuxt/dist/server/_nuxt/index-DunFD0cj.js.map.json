AM,OAAO,SAAS,EAAE,MAAM,IAAI,OAAO,IAAI,SAAS,IAAI,SAAS,GAAA,CAAI;AACvE,UAAM,UAAU,IAAI,KAAK;AACzB,UAAM,OAAO,IAAI,KAAK;AACtB,UAAM,QAAQ,IAAI,KAAK;;;QA9IZ,IAAG;AAAA,QAAU,OAAM;AAAA,MAAA,ukJA+ELN,cAAA,SAAAC,MAAA,IAAA,EAAK,IAAI,iZAUTD,cAAA,SAAAC,MAAA,IAAA,EAAK,KAAK,+ZAWZD,cAAA,SAAAC,MAAA,IAAA,EAAK,OAAO,4uBAUZK,eAAAL,MAAA,IAAA,EAAK,OAAO,gEASZA,MAAA,OAAA,CAAO,IAAA,cAAA,2PAGTA,MAAA,OAAA,IAAO,eAAA,cAAA;WACJA,MAAA,OAAA,GAAO;;;;;;UAIZA,MAAA,IAAA,GAAI;;;;;UACJA,MAAA,KAAA,GAAK;;;;;;;;;;;;;;;;;;AChId,QAAA,UAAAC,eAAAC,WAAA,EAAA,OAAM,oFAAgF,MAAA,CAAA,CAAA,+FAAA;;IAEhF,IAAG;AAAA,IAAI,OAAM;AAAA;qBAAvB,CAGW,GAAAN,QAAAC,UAAA,aAAA;;;;;UAFTC,YAAyD,QAAA,EAAnD,OAAM,6BAA4B,GAAC,KAAS;AAAA,UAClDA,YAA0B,cAApB,eAAa;AAAA;;;;;AAIL,QAAA,uCAAAO,gBAAA,oBAAA,KAAI,GAAG,YAAW,CAAA,CAAA,yoBAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;","names":["_push","_parent","_createVNode","_ssrRenderAttr","_unref","_ssrRenderAttrs","_mergeProps","_createBlock","_ssrRenderList","_ssrInterpolate"],"sources":["../../../../components/AppNav.vue","../../../../virtual:public?%2Fhero-placeholder.png","../../../../components/HeroSection.vue","../../../../components/AboutSection.vue","../../../../components/SkillsSection.vue","../../../../components/PortfolioSection.vue","../../../../components/ExperienceSection.vue","../../../../components/ClientsSection.vue","../../../../components/ContactSection.vue","../../../../components/AppFooter.vue"],"sourcesContent":["<template>\n  <nav class=\"fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-5 bg-navy-900/95 backdrop-blur-sm border-b border-gray-200 dark:border-white/5 shadow-sm dark:shadow-none\">\n    <!-- Logo -->\n    <NuxtLink to=\"/\" class=\"flex items-center gap-2 font-semibold text-lg mr-8\" style=\"color: var(--color-text)\">\n      <span class=\"text-accent-blue font-bold\">&lt;/&gt;</span>\n      <span>Oni Priscilla</span>\n    </NuxtLink>\n\n    <!-- Desktop Nav -->\n    <div class=\"hidden md:flex items-center justify-between flex-1 mr-6\">\n      <a href=\"#\" class=\"nav-link\">Home</a>\n      <a href=\"#about\" class=\"nav-link\">About</a>\n      <a href=\"#skills\" class=\"nav-link\">Skills</a>\n      <a href=\"#portfolio\" class=\"nav-link\">Projects</a>\n      <a href=\"#experience\" class=\"nav-link\">Experience</a>\n      <a href=\"#contact\" class=\"nav-link\">Contact</a>\n    </div>\n\n    <div class=\"flex items-center gap-3\">\n      <!-- Theme toggle -->\n      <button\n        class=\"w-9 h-9 rounded-lg flex items-center justify-center transition-colors duration-200 bg-gray-100 hover:bg-gray-200 dark:bg-white/5 dark:hover:bg-white/10\"\n        :aria-label=\"isDark ? 'Switch to light mode' : 'Switch to dark mode'\"\n        @click=\"toggleTheme\"\n      >\n        <!-- Sun (shown in dark mode) -->\n        <svg v-if=\"isDark\" class=\"w-4 h-4 text-yellow-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z\"/>\n        </svg>\n        <!-- Moon (shown in light mode) -->\n        <svg v-else class=\"w-4 h-4 text-gray-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z\"/>\n        </svg>\n      </button>\n\n      <!-- Hamburger -->\n      <button\n        class=\"md:hidden flex flex-col gap-1.5 p-1\"\n        @click=\"menuOpen = !menuOpen\"\n        aria-label=\"Toggle menu\"\n      >\n        <span class=\"hamburger-bar block w-6 h-0.5 transition-all\" :class=\"menuOpen ? 'rotate-45 translate-y-2' : ''\" />\n        <span class=\"hamburger-bar block w-6 h-0.5 transition-all\" :class=\"menuOpen ? 'opacity-0' : ''\" />\n        <span class=\"hamburger-bar block w-6 h-0.5 transition-all\" :class=\"menuOpen ? '-rotate-45 -translate-y-2' : ''\" />\n      </button>\n    </div>\n  </nav>\n\n  <!-- Mobile Menu -->\n  <Transition name=\"slide-down\">\n    <div v-if=\"menuOpen\" class=\"fixed top-[72px] left-0 right-0 z-40 bg-navy-800 border-b border-white/10 px-8 py-6 flex flex-col gap-4 md:hidden\">\n      <a href=\"#\" class=\"nav-link text-base\" @click=\"menuOpen = false\">Home</a>\n      <a href=\"#about\" class=\"nav-link text-base\" @click=\"menuOpen = false\">About</a>\n      <a href=\"#skills\" class=\"nav-link text-base\" @click=\"menuOpen = false\">Skills</a>\n      <a href=\"#portfolio\" class=\"nav-link text-base\" @click=\"menuOpen = false\">Projects</a>\n      <a href=\"#experience\" class=\"nav-link text-base\" @click=\"menuOpen = false\">Experience</a>\n      <a href=\"#contact\" class=\"nav-link text-base\" @click=\"menuOpen = false\">Contact</a>\n    </div>\n  </Transition>\n</template>\n\n<script setup lang=\"ts\">\nconst menuOpen = ref(false)\nconst isDark = ref(true)\n\nonMounted(() => {\n  // Read the class already set by app.vue's inline script — don't re-evaluate\n  isDark.value = document.documentElement.classList.contains('dark')\n})\n\nfunction toggleTheme() {\n  isDark.value = !isDark.value\n  document.documentElement.classList.toggle('dark', isDark.value)\n  localStorage.setItem('theme', isDark.value ? 'dark' : 'light')\n}\n</script>\n\n<style scoped>\n.slide-down-enter-active,\n.slide-down-leave-active {\n  transition: all 0.3s ease;\n}\n.slide-down-enter-from,\n.slide-down-leave-to {\n  opacity: 0;\n  transform: translateY(-10px);\n}\n\n.hamburger-bar {\n  background-color: var(--color-text);\n}\n</style>\n","import { publicAssetsURL } from '#internal/nuxt/paths';export default publicAssetsURL(\"/hero-placeholder.png\")","<template>\n  <section class=\"relative min-h-screen flex items-center bg-navy-900 overflow-hidden pt-[72px]\">\n\n    <!-- Background decorative elements -->\n    <div class=\"absolute top-1/4 left-1/2 w-96 h-96 bg-accent-blue/5 rounded-full blur-3xl pointer-events-none\" />\n    <div class=\"absolute bottom-1/4 right-1/4 w-64 h-64 bg-blue-800/10 rounded-full blur-2xl pointer-events-none\" />\n\n    <div class=\"w-full max-w-7xl mx-auto px-8 lg:px-16 flex flex-col lg:flex-row items-center justify-between gap-16\">\n\n      <!-- Left: Text -->\n      <div class=\"flex-1 flex flex-col items-start\">\n        <span class=\"inline-flex items-center gap-2 text-accent-blue text-xs font-bold tracking-[0.2em] uppercase mb-6\">\n          <span class=\"w-8 h-px bg-accent-blue\" />\n          Frontend Engineer\n        </span>\n\n        <h1 class=\"text-5xl lg:text-7xl font-extrabold leading-[1.05] text-gray-900 dark:text-white mb-6\">\n          Oni<br />\n          <span class=\"text-accent-blue\">Olajumoke</span><br />\n          Priscilla\n        </h1>\n\n        <p class=\"text-gray-600 dark:text-gray-400 text-base leading-relaxed max-w-sm mb-10\">\n          Results-driven Frontend Engineer specialising in Vue.js and React.js ecosystems. I transform complex product requirements into elegant, responsive UIs that delight users — proven across fintech and telecoms platforms serving millions globally.\n        </p>\n\n        <!-- CTAs -->\n        <div class=\"flex flex-wrap items-center gap-4 mb-12\">\n          <a\n            href=\"#portfolio\"\n            class=\"px-6 py-3 bg-accent-blue hover:bg-accent-blue-hover text-white text-sm font-semibold rounded-full transition-colors duration-200\"\n          >\n            View My Work\n          </a>\n          <a\n            href=\"#contact\"\n            class=\"px-6 py-3 border border-gray-300 dark:border-white/20 hover:border-gray-600 dark:hover:border-white/50 text-gray-900 dark:text-white text-sm font-semibold rounded-full transition-colors duration-200\"\n          >\n            Contact Me\n          </a>\n          <button\n            data-cal-link=\"priscilla-olajumoke-oni-myhwqz/secret\"\n            data-cal-namespace=\"secret\"\n            data-cal-config='{\"layout\":\"month_view\",\"useSlotsViewOnSmallScreen\":\"true\"}'\n            class=\"px-6 py-3 border border-accent-blue/40 hover:border-accent-blue text-accent-blue text-sm font-semibold rounded-full transition-colors duration-200\"\n          >\n            Book a Free Consultation\n          </button>\n        </div>\n\n        <!-- Social links -->\n        <div class=\"flex items-center gap-5\">\n          <a href=\"https://github.com/prolajumokeoni\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors\" aria-label=\"GitHub\">\n            <svg class=\"w-5 h-5\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path d=\"M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12\"/>\n            </svg>\n          </a>\n          <a href=\"https://www.linkedin.com/in/prolajumokeoni/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors\" aria-label=\"LinkedIn\">\n            <svg class=\"w-5 h-5\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path d=\"M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.41